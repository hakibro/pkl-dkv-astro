---
interface Props {
  title?: string;
}

const { title = 'SAYGON x DISKOMVIS Creative Lab Pitch Deck' } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  
  <!-- Google Fonts: Outfit (Agency Headings) & Plus Jakarta Sans (Clean Body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />
  
  <!-- FontAwesome for Premium Tech Icons -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />
  
  <!-- Import Styles -->
  <link rel="stylesheet" href="/src/styles/global.css" />
  <link rel="stylesheet" href="/src/styles/animations.css" />
</head>
<body class="font-jakarta text-white bg-obsidian bg-grid">
  <slot />
</body>
</html>
