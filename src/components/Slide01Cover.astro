---
// Slide 1: Cover with Logo and Hero Content
---

<div class="slide-frame active w-full" id="slide-1" data-slide="0">
  <div class="flex flex-col items-center justify-center text-center space-y-8 max-w-5xl mx-auto">
    <!-- Logo as Main Focus - Large and Prominent -->
    <div class="logo-container animate-float animate-fade-in-down delay-100">
      <img
        src="/images/logodiskomvisxsaygon.png"
        alt="DISKOMVIS x SAYGON Logo"
        class="w-96 md:w-[500px] h-auto animate-glow-pulse"
        style="filter: drop-shadow(0 15px 40px rgba(191, 255, 0, 0.4));"
      />
    </div>

    <!-- Hero Content Below Logo -->
    <div class="space-y-6">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-neonLime/30 bg-neonLime/5 text-neonLime text-sm font-bold font-outfit uppercase tracking-widest opacity-0 animate-fade-in-up delay-200">
        <i class="fa-solid fa-bolt"></i> Project-Based Industry Internship
      </span>
      
      <h1 class="font-outfit text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-white leading-none opacity-0 animate-fade-in-up delay-300">
        SAYGON × DISKOMVIS<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-neonLime via-cyan-400 to-neonIndigo">
          CREATIVE LAB
        </span>
      </h1>
      
      <p class="text-lg md:text-xl lg:text-2xl text-slate-400 font-light max-w-3xl mx-auto leading-relaxed opacity-0 animate-fade-in-up delay-400">
        Project-Based Industry Internship Program.
        <span class="text-white font-medium">Transforming Internship</span>
        Into Real Creative Industry Collaboration.
      </p>
    </div>

    <!-- Tags at Bottom -->
    <div class="pt-4 flex flex-wrap justify-center gap-3 opacity-0 animate-fade-in-up delay-500">
      <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm font-medium text-slate-300 hover-lift">
        <i class="fa-solid fa-code text-neonLime mr-2"></i>Web Development
      </span>
      <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm font-medium text-slate-300 hover-lift">
        <i class="fa-solid fa-compass-drafting text-neonIndigo mr-2"></i>Graphic Design
      </span>
      <span class="px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm font-medium text-slate-300 hover-lift">
        <i class="fa-solid fa-camera text-neonCoral mr-2"></i>Photography
      </span>
    </div>
  </div>
</div>
